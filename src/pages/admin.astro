---
import LayoutDefault from '~/layouts/LayoutDefault.astro'
---

<LayoutDefault>
  <div flex="~ col gap-6">
    <header>
      <h1 class="post-title">管理后台</h1>
      <p class="admin-desc">管理所有留言。你需要管理员密钥才能访问。</p>
    </header>

    <!-- Login form -->
    <div id="admin-login" class="admin-login">
      <label class="admin-label">
        <span>管理员密钥</span>
        <input type="password" id="admin-key-input" class="admin-input" placeholder="输入密钥..." />
      </label>
      <button id="admin-login-btn" class="admin-btn">进入</button>
      <p class="admin-hint">默认密钥: <code>admin123</code>（可在 Vercel 环境变量中设置 <code>ADMIN_KEY</code> 更改）</p>
    </div>

    <!-- Message list (hidden until auth) -->
    <div id="admin-panel" class="admin-panel hidden">
      <div class="admin-toolbar">
        <span id="admin-count" class="admin-count"></span>
        <button id="admin-refresh" class="admin-btn-sm">刷新</button>
        <button id="admin-logout" class="admin-btn-sm admin-btn-outline">退出</button>
      </div>
      <div id="admin-messages" class="admin-messages">
        <p class="admin-loading">加载中...</p>
      </div>
    </div>
  </div>
</LayoutDefault>

<style>
  .admin-desc {
    font-size: .9rem;
    opacity: .6;
    margin: .5rem 0 0;
  }

  .admin-login {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 400px;
  }

  .admin-label {
    display: flex;
    flex-direction: column;
    gap: .35rem;
    font-size: .875rem;
    font-weight: 500;
  }

  .admin-input {
    padding: .65rem .85rem;
    border: 1px solid color-mix(in srgb, var(--color-primary, #2e405b) 20%, transparent);
    border-radius: .5rem;
    font-size: .95rem;
    background: var(--color-background, #fff);
    color: var(--color-primary, #2e405b);
    font-family: inherit;
  }

  .admin-input:focus {
    outline: none;
    border-color: var(--color-primary, #2e405b);
  }

  .admin-btn {
    padding: .65rem 1.5rem;
    background: var(--color-primary, #2e405b);
    color: var(--color-background, #fff);
    border: none;
    border-radius: .5rem;
    font-size: .95rem;
    font-weight: 600;
    cursor: pointer;
    align-self: flex-start;
  }

  .admin-btn:hover { opacity: .85; }

  .admin-btn-sm {
    padding: .4rem 1rem;
    background: var(--color-primary, #2e405b);
    color: var(--color-background, #fff);
    border: none;
    border-radius: .4rem;
    font-size: .8rem;
    cursor: pointer;
    font-family: inherit;
  }

  .admin-btn-sm:hover { opacity: .85; }

  .admin-btn-outline {
    background: transparent;
    color: var(--color-primary, #2e405b);
    border: 1px solid color-mix(in srgb, var(--color-primary, #2e405b) 25%, transparent);
  }

  .admin-hint {
    font-size: .75rem;
    opacity: .4;
    margin: 0;
  }

  .admin-hint code {
    background: color-mix(in srgb, var(--color-primary, #2e405b) 8%, transparent);
    padding: .1rem .35rem;
    border-radius: .25rem;
    font-size: .75rem;
  }

  .admin-panel { gap: 1rem; }

  .admin-toolbar {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-primary, #2e405b) 10%, transparent);
  }

  .admin-count {
    flex: 1;
    font-size: .85rem;
    opacity: .7;
  }

  .admin-messages {
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .admin-loading {
    text-align: center;
    opacity: .4;
    padding: 2rem;
  }

  .admin-item {
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--color-primary, #2e405b) 10%, transparent);
    border-radius: .65rem;
    position: relative;
  }

  .admin-item-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: .4rem;
    gap: .75rem;
  }

  .admin-item-name {
    font-weight: 600;
    font-size: .9rem;
  }

  .admin-item-meta {
    display: flex;
    gap: .5rem;
    align-items: center;
  }

  .admin-badge {
    font-size: .65rem;
    padding: .15rem .45rem;
    border-radius: 999px;
    font-weight: 600;
  }

  .admin-badge-public {
    background: #22c55e20;
    color: #16a34a;
  }

  .admin-badge-private {
    background: #f59e0b20;
    color: #d97706;
  }

  .admin-badge-reply {
    background: #3b82f620;
    color: #2563eb;
    margin-left: .35rem;
    font-size: .65rem;
    padding: .15rem .45rem;
    border-radius: 999px;
    font-weight: 600;
  }

  .admin-item-date {
    font-size: .7rem;
    opacity: .4;
  }

  .admin-item-contact {
    font-size: .75rem;
    opacity: .4;
    margin-bottom: .4rem;
  }

  .admin-item-body {
    font-size: .85rem;
    opacity: .8;
    line-height: 1.65;
    margin: 0 0 .75rem;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .admin-delete-btn {
    padding: .3rem .85rem;
    background: #ef4444;
    color: #fff;
    border: none;
    border-radius: .35rem;
    font-size: .75rem;
    cursor: pointer;
    font-family: inherit;
  }

  .admin-delete-btn:hover { background: #dc2626; }
  .admin-delete-btn:disabled { opacity: .4; cursor: not-allowed; }

  .hidden { display: none !important; }
</style>

<script>
  let adminKey = ''

  function getHeaders() {
    return { 'x-admin-key': adminKey }
  }

  async function loadMessages() {
    const container = document.getElementById('admin-messages')
    const countEl = document.getElementById('admin-count')
    if (!container) return

    container.innerHTML = '<p class="admin-loading">加载中...</p>'

    try {
      const res = await fetch(`/api/message?key=${encodeURIComponent(adminKey)}`, {
        headers: getHeaders(),
      })
      if (!res.ok) throw new Error('Failed')
      const messages = await res.json()

      if (countEl) countEl.textContent = `共 ${messages.length} 条留言`

      if (!messages.length) {
        container.innerHTML = '<p class="admin-loading">暂无留言</p>'
        return
      }

      container.innerHTML = messages.map((msg: any) => `
        <div class="admin-item" id="msg-${msg.id}">
          <div class="admin-item-header">
            <span class="admin-item-name">
              ${escapeHtml(msg.name || 'Anonymous')}
              ${msg.parentId ? '<span class="admin-badge admin-badge-reply">回复</span>' : ''}
            </span>
            <div class="admin-item-meta">
              <span class="admin-badge ${msg.public ? 'admin-badge-public' : 'admin-badge-private'}">
                ${msg.public ? '公开' : '私密'}
              </span>
              <span class="admin-item-date">${new Date(msg.createdAt).toLocaleString('zh-CN')}</span>
            </div>
          </div>
          ${msg.contact ? `<div class="admin-item-contact">📧 ${escapeHtml(msg.contact)}</div>` : ''}
          ${msg.parentId ? `<div class="admin-item-contact">↳ 回复: ${escapeHtml(msg.parentId)}</div>` : ''}
          <p class="admin-item-body">${escapeHtml(msg.message)}</p>
          <button class="admin-delete-btn" onclick="deleteMsg('${msg.id}')">删除</button>
        </div>
      `).join('')
    } catch {
      container.innerHTML = '<p class="admin-loading">加载失败</p>'
    }
  }

  function escapeHtml(s: string): string {
    const div = document.createElement('div')
    div.textContent = s
    return div.innerHTML
  }

  async function deleteMsg(id: string) {
    if (!confirm('确定删除这条留言吗？所有回复也将被删除。此操作不可撤销。')) return

    const btn = document.querySelector(`#msg-${id} .admin-delete-btn`) as HTMLButtonElement | null
    if (btn) btn.disabled = true

    try {
      const res = await fetch(`/api/message?id=${encodeURIComponent(id)}&key=${encodeURIComponent(adminKey)}`, {
        method: 'DELETE',
        headers: getHeaders(),
      })
      if (res.ok) {
        const el = document.getElementById(`msg-${id}`)
        if (el) el.remove()
        // Update count
        const remaining = document.querySelectorAll('.admin-item').length
        const countEl = document.getElementById('admin-count')
        if (countEl) countEl.textContent = `共 ${remaining} 条留言`
      } else {
        alert('删除失败')
        if (btn) btn.disabled = false
      }
    } catch {
      alert('网络错误')
      if (btn) btn.disabled = false
    }
  }

  // Login
  const loginBtn = document.getElementById('admin-login-btn')
  const keyInput = document.getElementById('admin-key-input') as HTMLInputElement | null
  const refreshBtn = document.getElementById('admin-refresh')
  const logoutBtn = document.getElementById('admin-logout')

  loginBtn?.addEventListener('click', () => {
    adminKey = keyInput?.value || ''
    if (!adminKey) return

    fetch(`/api/message?key=${encodeURIComponent(adminKey)}`, { headers: getHeaders() })
      .then(res => {
        if (res.ok) {
          document.getElementById('admin-login')?.classList.add('hidden')
          document.getElementById('admin-panel')?.classList.remove('hidden')
          loadMessages()
        } else {
          alert('密钥错误')
        }
      })
      .catch(() => alert('网络错误'))
  })

  keyInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') loginBtn?.click()
  })

  refreshBtn?.addEventListener('click', loadMessages)

  logoutBtn?.addEventListener('click', () => {
    adminKey = ''
    document.getElementById('admin-login')?.classList.remove('hidden')
    document.getElementById('admin-panel')?.classList.add('hidden')
    if (keyInput) keyInput.value = ''
  })

  ;(window as any).deleteMsg = deleteMsg
</script>
