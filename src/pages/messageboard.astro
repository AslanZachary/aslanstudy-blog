---
import LayoutDefault from '~/layouts/LayoutDefault.astro'

const { translate: t } = Astro.locals

// Fetch public messages at build time (ISR-like on Vercel)
let messages: Array<{ id: string; name: string; message: string; createdAt: string }> = []
try {
  // In production, this calls the API. At build time, messages are fetched client-side.
} catch {
  // Will be loaded client-side
}

function formatDateStr(iso: string): string {
  const d = new Date(iso)
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`
}
---

<LayoutDefault>
  <div flex="~ col gap-6">
    <header>
      <h1 class="post-title">留言板</h1>
      <p class="board-desc">这里展示所有访客选择公开的留言。你也可以在<a href="/about">关于页面</a>留下你的足迹。</p>
    </header>

    <div id="board-messages" class="board-messages">
      <p class="board-loading">加载留言中...</p>
    </div>

    <template id="msg-template">
      <div class="board-item">
        <div class="board-item-header">
          <span class="board-item-name"></span>
          <span class="board-item-date"></span>
        </div>
        <p class="board-item-body"></p>
        <button class="board-reply-btn">回复</button>
        <div class="board-replies"></div>
      </div>
    </template>

    <template id="reply-form-template">
      <div class="reply-form-container">
        <form class="reply-form">
          <input type="text" name="reply-name" class="reply-input" placeholder="你的昵称（可选）" />
          <textarea name="reply-message" class="reply-textarea" rows="3" required placeholder="写下你的回复..."></textarea>
          <div class="reply-form-actions">
            <button type="submit" class="reply-submit-btn">回复</button>
            <button type="button" class="reply-cancel-btn">取消</button>
          </div>
          <p class="reply-form-error hidden"></p>
        </form>
      </div>
    </template>

    <div id="board-empty" class="board-empty hidden">
      <p>还没有公开留言。成为第一个留言的人吧！</p>
      <a href="/about" class="board-cta">前往留言</a>
    </div>
  </div>
</LayoutDefault>

<style>
  .board-desc {
    font-size: .9rem;
    opacity: .6;
    margin: .5rem 0 0;
    line-height: 1.6;
  }

  .board-desc a {
    color: var(--color-primary, #2e405b);
    opacity: .8;
  }

  .board-messages {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .board-loading {
    text-align: center;
    opacity: .4;
    padding: 2rem;
    font-size: .9rem;
  }

  .board-item {
    padding: 1.25rem;
    border: 1px solid color-mix(in srgb, var(--color-primary, #2e405b) 10%, transparent);
    border-radius: .75rem;
    transition: border-color .15s;
  }

  .board-item:hover {
    border-color: color-mix(in srgb, var(--color-primary, #2e405b) 25%, transparent);
  }

  .board-item-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: .5rem;
    gap: .75rem;
  }

  .board-item-name {
    font-weight: 600;
    font-size: .95rem;
    color: var(--color-primary, #2e405b);
  }

  .board-item-date {
    font-size: .75rem;
    opacity: .4;
    white-space: nowrap;
  }

  .board-item-body {
    font-size: .9rem;
    line-height: 1.75;
    opacity: .8;
    margin: 0;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .board-empty {
    text-align: center;
    padding: 3rem 1rem;
    opacity: .5;
  }

  .board-cta {
    display: inline-block;
    margin-top: .75rem;
    padding: .5rem 1.5rem;
    border: 1px solid color-mix(in srgb, var(--color-primary, #2e405b) 30%, transparent);
    border-radius: .5rem;
    color: var(--color-primary, #2e405b);
    text-decoration: none;
    font-size: .9rem;
    transition: background .15s;
  }

  .board-cta:hover {
    background: color-mix(in srgb, var(--color-primary, #2e405b) 5%, transparent);
  }

  /* Reply button */
  .board-reply-btn {
    margin-top: .6rem;
    padding: .25rem .75rem;
    background: transparent;
    color: var(--color-primary, #2e405b);
    border: 1px solid color-mix(in srgb, var(--color-primary, #2e405b) 25%, transparent);
    border-radius: .35rem;
    font-size: .75rem;
    cursor: pointer;
    font-family: inherit;
    transition: background .15s;
  }
  .board-reply-btn:hover {
    background: color-mix(in srgb, var(--color-primary, #2e405b) 6%, transparent);
  }

  /* Replies wrapper */
  .board-replies {
    margin-left: 2rem;
    margin-top: .75rem;
    padding-left: 1rem;
    border-left: 2px solid color-mix(in srgb, var(--color-primary, #2e405b) 12%, transparent);
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }
  .board-replies:empty { display: none; }

  /* Reply form */
  .reply-form-container {
    margin-top: .75rem;
    margin-left: 2rem;
    padding-left: 1rem;
    border-left: 2px solid color-mix(in srgb, var(--color-primary, #2e405b) 12%, transparent);
  }
  .reply-form {
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }
  .reply-input,
  .reply-textarea {
    width: 100%;
    padding: .5rem .7rem;
    border: 1px solid color-mix(in srgb, var(--color-primary, #2e405b) 18%, transparent);
    border-radius: .4rem;
    font-size: .85rem;
    background: var(--color-background, #fff);
    color: var(--color-primary, #2e405b);
    font-family: inherit;
    box-sizing: border-box;
  }
  .reply-input:focus,
  .reply-textarea:focus {
    outline: none;
    border-color: var(--color-primary, #2e405b);
  }
  .reply-textarea { resize: vertical; min-height: 60px; }
  .reply-form-actions {
    display: flex;
    gap: .5rem;
  }
  .reply-submit-btn {
    padding: .35rem 1rem;
    background: var(--color-primary, #2e405b);
    color: var(--color-background, #fff);
    border: none;
    border-radius: .35rem;
    font-size: .8rem;
    cursor: pointer;
    font-family: inherit;
  }
  .reply-submit-btn:hover { opacity: .85; }
  .reply-submit-btn:disabled { opacity: .5; cursor: not-allowed; }
  .reply-cancel-btn {
    padding: .35rem 1rem;
    background: transparent;
    color: var(--color-primary, #2e405b);
    border: 1px solid color-mix(in srgb, var(--color-primary, #2e405b) 20%, transparent);
    border-radius: .35rem;
    font-size: .8rem;
    cursor: pointer;
    font-family: inherit;
  }
  .reply-cancel-btn:hover {
    background: color-mix(in srgb, var(--color-primary, #2e405b) 5%, transparent);
  }
  .reply-form-error {
    color: #ef4444;
    font-size: .75rem;
    margin: 0;
  }

  .hidden { display: none; }
</style>

<script>
  async function loadMessages() {
    const container = document.getElementById('board-messages')
    const empty = document.getElementById('board-empty')
    if (!container || !empty) return

    try {
      const res = await fetch('/api/message')
      if (!res.ok) throw new Error('Failed')
      const messages = await res.json()

      if (!messages.length) {
        container.classList.add('hidden')
        empty.classList.remove('hidden')
        return
      }

      const msgTemplate = document.getElementById('msg-template') as HTMLTemplateElement | null
      if (!msgTemplate) return

      // Build tree: top-level and children map
      const topLevel: any[] = []
      const children: Record<string, any[]> = {}
      for (const msg of messages) {
        if (msg.parentId) {
          if (!children[msg.parentId]) children[msg.parentId] = []
          children[msg.parentId].push(msg)
        } else {
          topLevel.push(msg)
        }
      }

      const fragment = document.createDocumentFragment()
      for (const msg of topLevel) {
        const node = buildMessageNode(msg, msgTemplate, children[msg.id] || [])
        fragment.appendChild(node)
      }

      container.innerHTML = ''
      container.appendChild(fragment)
      container.classList.remove('hidden')
      empty.classList.add('hidden')
    } catch {
      container.innerHTML = '<p class="board-loading">加载失败，请刷新页面重试。</p>'
    }
  }

  function buildMessageNode(
    msg: any,
    template: HTMLTemplateElement,
    childMessages: any[]
  ): HTMLElement {
    const node = template.content.cloneNode(true) as DocumentFragment
    const itemEl = node.querySelector('.board-item') as HTMLElement

    const nameEl = itemEl.querySelector('.board-item-name')
    const dateEl = itemEl.querySelector('.board-item-date')
    const bodyEl = itemEl.querySelector('.board-item-body')
    const repliesEl = itemEl.querySelector('.board-replies')

    if (nameEl) nameEl.textContent = msg.name || 'Anonymous'
    if (dateEl) dateEl.textContent = new Date(msg.createdAt).toLocaleDateString(
      'zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })
    if (bodyEl) bodyEl.textContent = msg.message

    // Wire reply button
    const replyBtn = itemEl.querySelector('.board-reply-btn')
    if (replyBtn) {
      replyBtn.addEventListener('click', () => toggleReplyForm(itemEl, msg.id))
    }

    // Render child replies
    if (repliesEl && childMessages.length > 0) {
      for (const child of childMessages) {
        const childNode = buildMessageNode(child, template, [])
        repliesEl.appendChild(childNode)
      }
    }

    return itemEl
  }

  function toggleReplyForm(itemEl: HTMLElement, parentId: string) {
    // Remove any existing open reply form
    const existing = itemEl.querySelector('.reply-form-container')
    if (existing) { existing.remove(); return }

    const formTemplate = document.getElementById('reply-form-template') as HTMLTemplateElement | null
    if (!formTemplate) return

    const formNode = formTemplate.content.cloneNode(true) as DocumentFragment
    const formContainer = formNode.querySelector('.reply-form-container') as HTMLElement
    const form = formContainer.querySelector('.reply-form') as HTMLFormElement
    const cancelBtn = formContainer.querySelector('.reply-cancel-btn')
    const errorEl = formContainer.querySelector('.reply-form-error')

    // Insert form before replies section
    const repliesEl = itemEl.querySelector('.board-replies')
    if (repliesEl) {
      itemEl.insertBefore(formContainer, repliesEl)
    } else {
      itemEl.appendChild(formContainer)
    }

    cancelBtn?.addEventListener('click', () => formContainer.remove())

    form?.addEventListener('submit', async (e) => {
      e.preventDefault()
      const submitBtn = form.querySelector('.reply-submit-btn') as HTMLButtonElement | null
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = '...' }

      const data = new FormData(form)
      const name = (data.get('reply-name') as string || '').trim() || 'Anonymous'
      const message = (data.get('reply-message') as string || '').trim()

      if (!message) {
        if (errorEl) { errorEl.textContent = '请输入回复内容'; errorEl.classList.remove('hidden') }
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = '回复' }
        return
      }

      try {
        const res = await fetch('/api/message', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, message, parentId, type: 'comment', public: true }),
        })
        if (res.ok) {
          await loadMessages()
        } else {
          if (errorEl) { errorEl.textContent = '发送失败，请重试'; errorEl.classList.remove('hidden') }
          if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = '回复' }
        }
      } catch {
        if (errorEl) { errorEl.textContent = '网络错误，请稍后重试'; errorEl.classList.remove('hidden') }
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = '回复' }
      }
    })
  }

  loadMessages()
</script>
