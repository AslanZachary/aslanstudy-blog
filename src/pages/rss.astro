---
import LayoutDefault from '~/layouts/LayoutDefault.astro'
import { themeConfig } from '~/.config'

const feedUrl = `${themeConfig.site.website}/atom.xml`
const feedUrlEncoded = encodeURIComponent(feedUrl)

// Popular RSS reader subscribe links
const readers = [
  {
    name: 'Feedly',
    icon: 'i-mdi-rss-box',
    url: `https://feedly.com/i/subscription/feed/${feedUrlEncoded}`,
    desc: '最流行的 RSS 阅读器，支持 Web / iOS / Android',
  },
  {
    name: 'Inoreader',
    icon: 'i-mdi-rss',
    url: `https://www.inoreader.com/?add_feed=${feedUrlEncoded}`,
    desc: '功能强大的 RSS 阅读器，支持规则过滤和离线阅读',
  },
  {
    name: 'NewsBlur',
    icon: 'i-mdi-newspaper-variant-outline',
    url: `https://www.newsblur.com/?url=${feedUrlEncoded}`,
    desc: '开源 RSS 阅读器，支持社交分享和智能筛选',
  },
  {
    name: 'The Old Reader',
    icon: 'i-mdi-book-open-page-variant',
    url: `https://theoldreader.com/feeds/subscribe?url=${feedUrlEncoded}`,
    desc: '类 Google Reader 体验，简洁纯粹',
  },
  {
    name: 'RSS 阅读器扩展',
    icon: 'i-mdi-puzzle',
    url: 'https://chromewebstore.google.com/search/rss',
    desc: 'Chrome 扩展商店搜索 RSS 阅读器，直接在浏览器中订阅',
  },
]

// Desktop/mobile RSS reader apps
const apps = [
  { name: 'NetNewsWire', icon: 'i-mdi-apple', desc: 'macOS / iOS 最佳免费 RSS 阅读器', url: 'https://netnewswire.com/' },
  { name: 'Reeder', icon: 'i-mdi-apple-ios', desc: 'iOS / macOS 精致优雅的 RSS 阅读器', url: 'https://reederapp.com/' },
  { name: 'Fluent Reader', icon: 'i-mdi-laptop', desc: '跨平台桌面 RSS 阅读器，界面现代', url: 'https://hyliu.me/fluent-reader/' },
  { name: 'Miniflux', icon: 'i-mdi-server', desc: '自托管 RSS 服务，极简高效', url: 'https://miniflux.app/' },
  { name: 'FreshRSS', icon: 'i-mdi-cloud-cog', desc: '自托管 RSS 聚合器，功能全面', url: 'https://freshrss.org/' },
]
---

<LayoutDefault>
  <header flex="~ col gap-2">
    <h1 class="post-title">RSS 订阅</h1>
    <p class="subtitle-text">通过 RSS 订阅斯兰书房，第一时间获取新文章通知</p>
  </header>

  <!-- What is RSS -->
  <section class="rss-section">
    <h2 class="section-title">什么是 RSS？</h2>
    <div class="prose">
      <p>RSS（Really Simple Syndication）是一种内容订阅协议。你可以把它理解为<strong>一个不依赖任何平台的"关注"系统</strong>——当你订阅的博客发布新文章时，你的 RSS 阅读器会自动收到通知。</p>
      <ul>
        <li>不需要注册账号</li>
        <li>不需要提供邮箱</li>
        <li>不会被算法推荐干扰</li>
        <li>不会漏掉任何一篇文章</li>
        <li>你完全掌控自己的阅读列表</li>
      </ul>
    </div>
  </section>

  <!-- Feed URL -->
  <section class="rss-section">
    <h2 class="section-title">你的订阅地址</h2>
    <div class="feed-url-box">
      <code class="feed-url">{feedUrl}</code>
      <button class="copy-btn" id="copy-btn" data-url={feedUrl}>
        <span class="i-mdi-content-copy"></span>
        <span>复制</span>
      </button>
    </div>
    <p class="hint-text">点击上方按钮复制链接，粘贴到任意 RSS 阅读器即可完成订阅。</p>
  </section>

  <!-- One-click subscribe -->
  <section class="rss-section">
    <h2 class="section-title">一键订阅到在线阅读器</h2>
    <p class="section-desc">点击下方按钮，直接跳转到对应阅读器完成订阅：</p>
    <div class="reader-grid">
      {readers.map((r) => (
        <a href={r.url} target="_blank" rel="noopener noreferrer" class="reader-card">
          <span class={`reader-icon ${r.icon}`}></span>
          <div class="reader-info">
            <span class="reader-name">{r.name}</span>
            <span class="reader-desc">{r.desc}</span>
          </div>
          <span class="i-mdi-arrow-right reader-arrow"></span>
        </a>
      ))}
    </div>
  </section>

  <!-- Apps -->
  <section class="rss-section">
    <h2 class="section-title">推荐 RSS 阅读应用</h2>
    <p class="section-desc">如果你更喜欢使用本地应用阅读，以下是推荐的 RSS 客户端：</p>
    <div class="reader-grid">
      {apps.map((a) => (
        <a href={a.url} target="_blank" rel="noopener noreferrer" class="reader-card">
          <span class={`reader-icon ${a.icon}`}></span>
          <div class="reader-info">
            <span class="reader-name">{a.name}</span>
            <span class="reader-desc">{a.desc}</span>
          </div>
          <span class="i-mdi-open-in-new reader-arrow"></span>
        </a>
      ))}
    </div>
  </section>

  <!-- How to use -->
  <section class="rss-section">
    <h2 class="section-title">如何使用？</h2>
    <div class="prose">
      <ol>
        <li><strong>选择阅读器</strong>：从上方推荐中选择一个在线阅读器或本地应用</li>
        <li><strong>添加订阅源</strong>：将上方订阅地址粘贴到阅读器的"添加订阅"输入框中</li>
        <li><strong>完成</strong>：每当本博客发布新文章，你的阅读器就会自动显示</li>
      </ol>
      <p>如果你更习惯通过邮箱接收更新，可以点击右下角的 <strong>邮件订阅</strong> 按钮，新文章将直接发送到你的邮箱。</p>
    </div>
  </section>
</LayoutDefault>

<style>
  .subtitle-text {
    font-size: 1.05rem;
    opacity: .55;
    margin: 0;
  }

  .rss-section {
    margin-top: 2.5rem;
  }

  .section-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0 0 .75rem;
    color: var(--color-primary, #2e405b);
  }

  .section-desc {
    font-size: .9rem;
    opacity: .55;
    margin: 0 0 1rem;
  }

  .prose {
    font-size: .95rem;
    line-height: 1.85;
    opacity: .75;
  }

  .prose ul, .prose ol {
    padding-left: 1.5rem;
    margin: .75rem 0;
  }

  .prose li {
    margin: .35rem 0;
  }

  .prose a {
    color: var(--color-primary, #2e405b);
    text-decoration: underline;
  }

  /* Feed URL box */
  .feed-url-box {
    display: flex;
    align-items: center;
    gap: .75rem;
    background: color-mix(in srgb, var(--color-primary, #2e405b) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-primary, #2e405b) 15%, transparent);
    border-radius: .75rem;
    padding: .85rem 1rem;
    flex-wrap: wrap;
  }

  .feed-url {
    flex: 1;
    font-size: .9rem;
    word-break: break-all;
    color: var(--color-primary, #2e405b);
    opacity: .75;
    min-width: 0;
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    padding: .5rem 1rem;
    border: 1px solid var(--color-primary, #2e405b);
    border-radius: .5rem;
    background: var(--color-primary, #2e405b);
    color: var(--color-background, #fff);
    font-size: .85rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity .15s;
    font-family: inherit;
  }

  .copy-btn:hover { opacity: .85; }
  .copy-btn.copied {
    background: #22c55e;
    border-color: #22c55e;
  }

  .hint-text {
    font-size: .8rem;
    opacity: .4;
    margin: .5rem 0 0;
  }

  /* Reader cards */
  .reader-grid {
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }

  .reader-card {
    display: flex;
    align-items: center;
    gap: .85rem;
    padding: .85rem 1rem;
    border: 1px solid color-mix(in srgb, var(--color-primary, #2e405b) 12%, transparent);
    border-radius: .6rem;
    text-decoration: none;
    color: var(--color-primary, #2e405b);
    transition: background .15s, border-color .15s;
  }

  .reader-card:hover {
    background: color-mix(in srgb, var(--color-primary, #2e405b) 4%, transparent);
    border-color: color-mix(in srgb, var(--color-primary, #2e405b) 30%, transparent);
  }

  .reader-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    opacity: .7;
    width: 2rem;
    text-align: center;
  }

  .reader-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: .15rem;
    min-width: 0;
  }

  .reader-name {
    font-weight: 600;
    font-size: .95rem;
  }

  .reader-desc {
    font-size: .8rem;
    opacity: .5;
  }

  .reader-arrow {
    flex-shrink: 0;
    opacity: .3;
    font-size: 1.1rem;
  }
</style>

<script>
  const copyBtn = document.getElementById('copy-btn')
  if (copyBtn) {
    copyBtn.addEventListener('click', () => {
      const url = copyBtn.dataset.url || ''
      navigator.clipboard.writeText(url).then(() => {
        copyBtn.classList.add('copied')
        const span = copyBtn.querySelector('span:last-child')
        if (span) span.textContent = '已复制!'
        setTimeout(() => {
          copyBtn.classList.remove('copied')
          if (span) span.textContent = '复制'
        }, 2000)
      }).catch(() => {
        // Fallback for older browsers
        const textarea = document.createElement('textarea')
        textarea.value = url
        textarea.style.position = 'fixed'
        textarea.style.opacity = '0'
        document.body.appendChild(textarea)
        textarea.select()
        document.execCommand('copy')
        document.body.removeChild(textarea)
        const span = copyBtn.querySelector('span:last-child')
        if (span) span.textContent = '已复制!'
        setTimeout(() => {
          if (span) span.textContent = '复制'
        }, 2000)
      })
    })
  }
</script>
